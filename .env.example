# Environment Configuration - GESTICOM Frontend
# Copiez ce fichier vers .env et configurez vos valeurs

# Mode de l'application
# Options: development, production
VITE_APP_ENV=production

# API Base URL - Backend
# En développement (localhost)
VITE_API_URL=http://localhost:3000/api

# En production (Render) - Used when VITE_APP_ENV=production
VITE_API_URL_PRODUCTION=https://gestion-caisse.onrender.com/api

# URL du frontend (pour les redirections CORS)
VITE_FRONTEND_URL=http://localhost:5173
VITE_FRONTEND_URL_PRODUCTION=https://gestion-caisse-frontend.vercel.app
